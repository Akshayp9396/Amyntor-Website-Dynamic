# Amyntor Tech Backend Environment Configuration
# Use this file as a template for your local .env

# Server Configuration
PORT=5000
NODE_ENV=development

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=amyntortech_db

# Security & JWT
JWT_SECRET=amyntor_super_secret_key_2024
JWT_EXPIRE=30d

# Email Configuration (Nodemailer)
# For Gmail, use an "App Password" (Security > 2FA > App Passwords)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_RECEIVER=info@amyntortech.com
